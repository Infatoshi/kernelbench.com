#!/usr/bin/env bash
# kb — thin shim. The real CLI is the uv-installable `kbtool` package
# (kbtool/kb/cli.py). This shim resolves the repo root and delegates through
# `uv run` so it works with no global install. Equivalent direct install:
#   uv tool install ./kbtool   (then `kb` is on PATH on its own)
set -euo pipefail
KB="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$KB")/.." && pwd)"   # bin/kb -> repo root
export KB_REPO_ROOT="$ROOT"
exec uv run --quiet --project "$ROOT/kbtool" python -m kb "$@"
