#!/usr/bin/env bash
# kb — KernelBench operator CLI. Drives the kernelbench.com monorepo on Anvil:
# run sweeps, publish results, deploy the site. Resolves the repo from its own
# location, so it works from any cwd.
set -euo pipefail

KB="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$KB")/.." && pwd)"   # bin/kb -> repo root
HARD="$ROOT/benchmarks/hard"

usage() {
  cat <<EOF
kb — KernelBench operator CLI   (repo: $ROOT)

  kb sweep <harness> <model> [effort]   full 6-problem sweep, parallel containers, 2700s
  kb run <harness> <model> <problem> [effort]   one problem (problem = e.g. 05_topk_bitonic)
  kb publish                            rebuild leaderboard + transcript viewers from archives
  kb deploy [message]                   publish, commit, push -> Vercel deploys
  kb dev                                preview site locally (view from Mac via Tailscale anvil:3000)
  kb build                              next build
  kb audit <run_id>                     print a run's result + annotation verdict
  kb lint <run_id|--all>                static reward-hack tripwire (scans solution.py)
  kb help

Keys live in ~/.env_vars. Bench a new model: add its key, then  kb sweep <harness> <model>.
Harnesses: claude codex cursor gemini grok opencode | zai-claude minimax-claude kimi-claude deepseek-claude qwen-claude
EOF
}

# Preflight: stop before launching if the env API key the harness needs is
# absent, with a message the operator (or an agent) can act on directly.
preflight_key() {
  local harness="$1" model="${2:-}" need=""
  [ -f "$HOME/.env_vars" ] && . "$HOME/.env_vars" 2>/dev/null || true
  case "$harness" in
    kimi-claude) need=KIMI_API_KEY ;;
    zai-claude) need=ZAI_API_KEY ;;
    minimax-claude) need=MINIMAX_API_KEY ;;
    deepseek-claude) need=DEEPSEEK_API_KEY ;;
    qwen-claude) need=DASHSCOPE_API_KEY ;;
    gemini) need=GEMINI_API_KEY ;;
    opencode-nemotron) need=OPENROUTER_API_KEY ;;
    opencode)
      case "$model" in
        openrouter-*|*/qwen/*|*/xiaomi/*|moonshotai/*) need=OPENROUTER_API_KEY ;;
        deepseek/*) need=DEEPSEEK_API_KEY ;;
        zai/*) need=ZAI_API_KEY ;;
      esac ;;
  esac
  if [ -n "$need" ] && [ -z "${!need:-}" ]; then
    echo "STOP: $harness/$model needs \$$need, which is not set in ~/.env_vars." >&2
    echo "  Add it:  echo 'export $need=sk-...' >> ~/.env_vars   (then rerun)" >&2
    exit 3
  fi
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  sweep)   preflight_key "${1:-}" "${2:-}"; exec "$HARD/scripts/sweep_deck.sh" "$@" ;;
  run)
    h="${1:?harness}"; m="${2:?model}"; p="${3:?problem}"; e="${4:-}"
    preflight_key "$h" "$m"
    cd "$HARD" && KBH_AGENT_CONTAINER=1 exec uv run kbh run "$h" "$m" "problems/$p" $e ;;
  publish) exec "$HARD/scripts/publish_v2.sh" ;;
  deploy)
    msg="${1:-publish kernelbench results}"
    "$HARD/scripts/publish_v2.sh"
    cd "$ROOT"
    git add -A benchmarks/hard/results public/runs app
    git -c user.email=elliot@arledge.net commit -m "$msg" || { echo "nothing to commit"; exit 0; }
    git push origin master
    echo "pushed; Vercel auto-builds." ;;
  dev)     cd "$ROOT" && exec npm run dev ;;
  build)   cd "$ROOT" && exec npm run build ;;
  audit)
    rid="${1:?run_id}"; d="$HARD/outputs/runs/$rid"
    [ -d "$d" ] || { echo "no such run: $rid" >&2; exit 1; }
    python3 -c "import json;r=json.load(open('$d/result.json'));print({k:r.get(k) for k in ('harness','model','correct','peak_fraction','template_mutated','failure_reason')})"
    a="$HARD/results/annotations/$rid.yaml"; [ -f "$a" ] && { echo "--- annotation ---"; cat "$a"; } ;;
  lint)    exec python3 "$HARD/scripts/reward_hack_lint.py" "$@" ;;
  help|-h|--help) usage ;;
  *) echo "unknown command: $cmd" >&2; usage; exit 2 ;;
esac
