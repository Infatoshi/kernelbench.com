{
  "PORT": 3456,
  "HOST": "127.0.0.1",
  "API_TIMEOUT_MS": 1800000,
  "Providers": [
    {
      "name": "deepseek",
      "api_base_url": "https://api.deepseek.com",
      "api_key": "${DEEPSEEK_API_KEY}",
      "models": [
        "deepseek-v4-pro",
        "deepseek-v4-flash",
        "deepseek-chat",
        "deepseek-reasoner"
      ],
      "transformer": {
        "use": ["anthropic", "deepseek"]
      }
    },
    {
      "name": "zai",
      "api_base_url": "https://api.z.ai/api/paas/v4",
      "api_key": "${ZAI_API_KEY}",
      "models": [
        "glm-5.1",
        "glm-5"
      ],
      "transformer": {
        "use": ["anthropic", "glm"]
      }
    },
    {
      "name": "minimax",
      "api_base_url": "https://api.minimaxi.com/v1",
      "api_key": "${MINIMAX_API_KEY}",
      "models": [
        "minimax-m2.7",
        "MiniMax-M2.7"
      ],
      "transformer": {
        "use": ["anthropic", "minimax"]
      }
    }
  ],
  "Router": {
    "default": "deepseek,deepseek-v4-pro"
  }
}
